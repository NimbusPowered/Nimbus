<?xml version="1.0" encoding="UTF-8"?>
<!--
  Opt-in JSON log configuration, activated by NIMBUS_LOG_FORMAT=json.
  Every line is a single JSON object with timestamp, level, thread,
  logger, message, and MDC fields. Designed for ingestion into Loki,
  Elasticsearch, Splunk, etc.

  The rolling policy matches logback.xml so `logs/latest.log` behaves
  identically in both modes; only the encoder differs.
-->
<configuration>
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/latest.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
            <fileNamePattern>logs/latest.%i.log</fileNamePattern>
            <minIndex>1</minIndex>
            <maxIndex>3</maxIndex>
        </rollingPolicy>
        <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
            <maxFileSize>50MB</maxFileSize>
        </triggeringPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</timestampPattern>
            <includeMdcKeyName>service_name</includeMdcKeyName>
            <includeMdcKeyName>group_name</includeMdcKeyName>
            <includeMdcKeyName>node_id</includeMdcKeyName>
            <includeMdcKeyName>request_id</includeMdcKeyName>
            <includeMdcKeyName>api_user</includeMdcKeyName>
        </encoder>
    </appender>

    <logger name="io.ktor" level="WARN" />
    <logger name="io.netty" level="WARN" />

    <root level="INFO">
        <appender-ref ref="FILE" />
    </root>
</configuration>
